<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>

  <view class="content">
    <view class="hero">
      <view class="hero-kicker">PARKING CLOUD</view>
      <view class="hero-title">
        停车场管理
        <text class="hero-title-accent">微信端登录</text>
      </view>
      <view class="hero-subtitle">登录后可查看剩余车位、预约车位，并查询当前账号对应车牌的进出记录。</view>
    </view>

    <view class="panel auth-panel">
      <view class="panel-title">欢迎回来</view>
      <view class="panel-subtitle">使用账号和密码进入停车场管理系统</view>

      <view class="field">
        <text class="field-label">用户名</text>
        <input class="field-input" placeholder="请输入用户名" data-field="username" bindinput="onInput" />
      </view>

      <view class="field">
        <text class="field-label">密码</text>
        <input class="field-input" password="true" placeholder="请输入密码" data-field="password" bindinput="onInput" />
      </view>

      <button class="primary-btn" loading="{{loading}}" bindtap="submit">立即登录</button>
      <button class="ghost-btn" bindtap="toRegister">没有账号，去注册</button>
    </view>
  </view>
</view>