<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>

  <view class="content">
    <view class="hero">
      <view class="hero-kicker">MY RECORDS</view>
      <view class="hero-title">进出记录</view>
      <view class="hero-subtitle">这里仅显示当前账号绑定车牌对应的入场、出场与停车费用信息。</view>
    </view>

    <view class="panel">
      <view class="panel-title">车辆通行明细</view>
      <view class="panel-subtitle">按时间倒序展示最近停车记录</view>

      <view wx:if="{{records.length === 0}}" class="empty">暂时还没有进出记录，完成一次入场后会显示在这里。</view>

      <view wx:else class="record-list">
        <view wx:for="{{records}}" wx:key="_id" class="record-item">
          <view class="record-head">
            <view class="record-plate">{{item.plate_no}}</view>
            <view class="status-pill {{item.status === 'finished' ? '' : 'warn'}}">{{item.status === 'finished' ? '已完成' : '在场中'}}</view>
          </view>
          <view class="record-meta">
            <view>入场时间：{{item.in_text}}</view>
            <view>出场时间：{{item.out_text}}</view>
            <view>停车时长：{{item.duration_s || 0}} 秒</view>
            <view>停车费用：{{item.fee_text}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>